<div>
    <neura::modal.header managed>
        <neura::heading level="h5" size="sm">
            [title]
        </neura::heading>
    </neura::modal.header>

    <neura::modal.body>
        {{-- Modal Content --}}
        <neura::text>
            Modal content goes here...
        </neura::text>
    </neura::modal.body>

    <neura::modal.footer>
        <neura::button variant="ghost" wire:click="closeModal">
            {{ __('Cancel') }}
        </neura::button>
        <neura::button variant="primary">
            {{ __('Confirm') }}
        </neura::button>
    </neura::modal.footer>
</div>

