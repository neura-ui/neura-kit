{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": false,
    "skipLibCheck": true,
    "types": ["node", "vite/client"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["resources/js/**/*"]
}
  